+        np.array([1.0, 2.0]),
+        np.array([-2.0, -2.0]),
+        np.array([2.0, 2.0]),
+        np.array([-2.0, -2.0]),
+        np.array([2.0, 2.0]),
+        np.array([-20.0, -20.0]),
