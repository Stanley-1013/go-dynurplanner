   635	        # D-UOAR-CT: swept integral + continuous TTC, both analytic.
   636	        msegs = self._moving_segments(dq)
   637	        total_len = sum(
   638	            np.linalg.norm(s[1] - s[0]) for s in self.kin.segments(self.q)
   639	        )
