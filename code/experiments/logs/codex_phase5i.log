+
+    assert constrained.stats["shield_fallback"] == 1
+    assert np.all(np.isfinite(constrained_margins))
+    assert np.all((0.0 <= constrained_margins) & (constrained_margins <= 1.0))
+    assert constrained_margins[0] < comfortable_margins[0]
+
+
