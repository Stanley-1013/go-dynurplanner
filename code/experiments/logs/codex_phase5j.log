+        raise ValueError(
+            f"{spec.path}: actor action width {action_dim} != env {env.action_dim}"
+        )
+    agent = TD3(
+        env.state_dim,
+        env.action_dim,
+        action_scale=env.action_bound[1],
+        expl_noise=0.25,
+        seed=spec.seed,
+    )
+    agent.actor.load_state_dict(actor_state)
+    agent.actor.eval()
+    env.set_difficulty(*spec.stage)
+
