import sys, numpy as np
sys.path.insert(0,'code')
from godynur.env import DynArmEnv
from godynur.panda import DQ_MAX

def act(env):
    q=env.q; p=env.kin.flange(q); e=env.goal-p
    eps=1e-5
    J=np.column_stack([(env.kin.flange(q+eps*np.eye(7)[i])-env.kin.flange(q-eps*np.eye(7)[i]))/(2*eps) for i in range(7)])
    speed=min(0.7, 4*np.linalg.norm(e))
    cart=speed*e/max(np.linalg.norm(e),1e-9)
    lam=.03
    qd=J.T@np.linalg.solve(J@J.T+lam**2*np.eye(3),cart)
    qd=np.clip(qd,-0.7*DQ_MAX,0.7*DQ_MAX)
    return np.clip((qd-env.v)/env.dv_scale,-1,1)

env=DynArmEnv(task='tabletop',n_obstacles=3,reward_mode='uoar',seed=2010000,action_mode='velocity')
env.set_difficulty(0,0.)
for ep in range(10):
    env.reset(); d0=np.linalg.norm(env.kin.flange(env.q)-env.goal); vs=[]
    done=False
    while not done:
       _,_,done=env.step(act(env));vs.append(np.linalg.norm(env.v))
    print(ep, 'd0', round(d0,3),'end',round(np.linalg.norm(env.kin.flange(env.q)-env.goal),4),'term', 'succ' if env.on_goal else ('coll' if env.last_tau_star is not None else 'timeout'), 'steps',env.t,'vmed',round(float(np.median(vs)),3),'vmax',round(max(vs),3),'fallback',env.stats)
