+            fractions.append(float(np.linalg.norm(env.v / DQ_MAX) / np.sqrt(env.action_dim)))
+            interventions += int(not env._last_terminal_membership)
+            if env.t in SNAPSHOT_STEPS:
+                snapshots[str(env.t)] = norm
+        episodes.append(
+            {
+                "episode": episode,
