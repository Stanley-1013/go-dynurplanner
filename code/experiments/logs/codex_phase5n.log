                          'alpha': 180, 'beta': 0, 'gamma': 0, 'oe': 6}      # oe: orientation error (degree)
        # Initial state of the manipulator, which will be reset to this value each episode.
        self.arm_info = [0, 0, 0, -90 * np.pi / 180, 0, 90 * np.pi / 180, 45 * np.pi / 180]

        # Use on_goal to indicate if the manipulator has reached the goal within max permitted errors.
        self.on_goal = 0
        # Normalization for distance
        self.dist_norm = 3
        self.orient_norm = 180

        self.total_link_length = 0.9101

        self.robot_box_intersection = Ray_Box_Intersection
        # radium for robot: 0.07
        self.box1 = self.robot_box_intersection.Box(self.robot_box_intersection.Point(-0.6798, -0.865, 0.67),
                                                    self.robot_box_intersection.Point(-0.2698, -0.005, 0.95))
        self.box2 = self.robot_box_intersection.Box(self.robot_box_intersection.Point(-0.6798, -0.64, 0),
                                                    self.robot_box_intersection.Point(-0.2698, -0.23, 0.67))
        self.box3 = self.robot_box_intersection.Box(self.robot_box_intersection.Point(-0.6798, -0.215, 1.07),
                                                    self.robot_box_intersection.Point(-0.2698, 0.845, 1.35))
        self.box4 = self.robot_box_intersection.Box(self.robot_box_intersection.Point(-0.6798, 0.11, 0),
                                                    self.robot_box_intersection.Point(-0.2698, 0.52, 1.07))

    def step(self, action):
        """
        step() function is used to execute the actions output by DRL, which returns some observations.
        In this implementation, we use pure mathematical model to accelerate the training speed.
        """
        done = False

        # convert to radian and calculate the current joint angles
        action = action * np.pi / 180
        self.arm_info = self.arm_info + action

        # restrict the calculated joint angles to the max rotation range of the manipulator's joints
        # refer to the joint limit of Franka
        self.arm_info[0] = np.clip(self.arm_info[0], -166 * np.pi / 180, 166 * np.pi / 180)
        self.arm_info[1] = np.clip(self.arm_info[1], -101 * np.pi / 180, 101 * np.pi / 180)
        self.arm_info[2] = np.clip(self.arm_info[2], -166 * np.pi / 180, 166 * np.pi / 180)
        self.arm_info[3] = np.clip(self.arm_info[3], -176 * np.pi / 180, -4 * np.pi / 180)
        self.arm_info[4] = np.clip(self.arm_info[4], -166 * np.pi / 180, 166 * np.pi / 180)
        self.arm_info[5] = np.clip(self.arm_info[5], -1 * np.pi / 180, 215 * np.pi / 180)
        self.arm_info[6] = np.clip(self.arm_info[6], -166 * np.pi / 180, 166 * np.pi / 180)

        # Calculate the pose information of TCP by forward kinematics
        T, finger_orient, finger_xyz = self.get_fk_solution(self.arm_info)

        # Calculate normalized x,y,z distances between TCP and goal
        dist1 = [(self.goal_pose['x'] - finger_xyz[0]) / self.dist_norm,
                 (self.goal_pose['y'] - finger_xyz[1]) / self.dist_norm,
                 (self.goal_pose['z'] - finger_xyz[2]) / self.dist_norm]

        # Orientation (alpha,beta,gamma) differences between TCP and goal, normalized
        dist2 = [np.abs(self.goal_pose['alpha'] - finger_orient[0]),
                 np.abs(self.goal_pose['beta'] - finger_orient[1]),
                 np.abs(self.goal_pose['gamma'] - finger_orient[2])]

        for m in range(3):
            if dist2[m] >= 180:
                dist2[m] = np.abs(dist2[m]-360)

        # Distances between TCP and goal, normalized
        delta_pos = np.sqrt(dist1[0] ** 2 + dist1[1] ** 2 + dist1[2] ** 2)

        """
        Difference of orientation between TCP and goal, normalized
        Use the first form if control of gamma necessary, otherwise use the second form.
        """
        delta_orient = (dist2[0] + dist2[1] + dist2[2]) / (3 * self.orient_norm)
        # delta_orient = (np.abs(dist2[0]) + np.abs(dist2[1])) / 2

        """r1: pose reward."""
        r = - delta_pos - delta_orient

        """r2"""
        self.distance_new = np.sqrt(dist1[0] ** 2 + dist1[1] ** 2 + dist1[2] ** 2)
        if self.distance_new < self.distance_old:
            r += 0.05
        elif self.distance_new > self.distance_old:
            r -= 0.05
        self.distance_old = self.distance_new.copy()

        self.orient_new = dist2[0] + dist2[1] + dist2[2]
        if self.orient_new < self.orient_old:
            r += 0.03
        elif self.orient_new > self.orient_old:
            r -= 0.03
        self.orient_old = self.orient_new.copy()

        """r4: collision avoidance"""
        total_intersection_length = self.get_link_box_intersection()
        # print('total_intersection_length:', total_intersection_length)
        r -= total_intersection_length / self.total_link_length

        """ r3: If TCP is within max permitted errors, r3 = 1. """
        # If TCP stays within the max permitted errors for 50 consecutive steps, the task is done.
        # position
        if self.goal_pose['x']-self.goal_pose['pe'] < finger_xyz[0] < self.goal_pose['x']+self.goal_pose['pe']:
            if self.goal_pose['y']-self.goal_pose['pe'] < finger_xyz[1] < self.goal_pose['y']+self.goal_pose['pe']:
                if self.goal_pose['z']-self.goal_pose['pe'] < finger_xyz[2] < self.goal_pose['z']+self.goal_pose['pe']:
                    # orientation
                    if dist2[0] <= self.goal_pose['oe']:
                        if dist2[1] <= self.goal_pose['oe']:
                            if dist2[2] <= self.goal_pose['oe']:
                                self.on_goal += 1
                                r += 1
                                if self.on_goal >= 50:  # >=50
                                    done = True
        else:
            self.on_goal = 0

        """
        state (20D): joint angles (7D),
                     TCP position (3D),
                     goal position (3D),
                     x,y,z deviation (3D),
                     alpha, beta, gamma deviation (3D),
                     done (1D).
        """
        s = np.concatenate((self.arm_info,
                            np.array([finger_xyz[0], finger_xyz[1], finger_xyz[2]]) / self.dist_norm,
                            np.array([self.goal_pose['x'], self.goal_pose['y'], self.goal_pose['z']]) / self.dist_norm,
                            dist1,
                            np.array([dist2[0]/self.orient_norm, dist2[1]/self.orient_norm, dist2[2]/self.orient_norm]),
                            [1. if self.on_goal else 0.]))

        return s, r, done, delta_pos, delta_orient

    def reset(self):
        """
        reset() function is used to randomly initialize the environment for each episode
        """
        self.goal_pose['x'] = -0.71
        self.goal_pose['y'] = -0.04 + (2 * np.random.rand() - 1) * 0.02
        self.goal_pose['z'] = 0.70 + (2 * np.random.rand() - 1) * 0.02

        self.on_goal = 0
        self.arm_info = [0, 0, 0, -90 * np.pi / 180, 0, 90 * np.pi / 180, 45 * np.pi / 180]

        # Calculate the pose information of TCP by forward kinematics
        T, finger_orient, finger_xyz = self.get_fk_solution(self.arm_info)

        # Calculate normalized x,y,z distances between TCP and goal
        dist1 = [(self.goal_pose['x'] - finger_xyz[0]) / self.dist_norm,
                 (self.goal_pose['y'] - finger_xyz[1]) / self.dist_norm,
                 (self.goal_pose['z'] - finger_xyz[2]) / self.dist_norm]

        # Orientation (alpha,beta,gamma) differences between TCP and goal, normalized
        dist2 = [np.abs(self.goal_pose['alpha'] - finger_orient[0]),
                 np.abs(self.goal_pose['beta'] - finger_orient[1]),
                 np.abs(self.goal_pose['gamma'] - finger_orient[2])]

        for m in range(3):
            if dist2[m] >= 180:
                dist2[m] = np.abs(dist2[m]-360)

        self.distance_old = np.sqrt(dist1[0] ** 2 + dist1[1] ** 2 + dist1[2] ** 2)
        self.orient_old = dist2[0] + dist2[1] + dist2[2]

        """
        state (20D): joint angles (7D),
                     TCP position (3D),
                     goal position (3D),
                     x,y,z deviation (3D),
                     alpha, beta, gamma deviation (3D),
                     done (1D).
        """
        s = np.concatenate((self.arm_info,
                            np.array([finger_xyz[0], finger_xyz[1], finger_xyz[2]]) / self.dist_norm,
                            np.array([self.goal_pose['x'], self.goal_pose['y'], self.goal_pose['z']]) / self.dist_norm,
                            dist1,
                            np.array([dist2[0]/self.orient_norm, dist2[1]/self.orient_norm, dist2[2]/self.orient_norm]),
                            [1. if self.on_goal else 0.]))
        return s

    def reset_test_env(self):
        """
        reset_test_env() function is used to initialize the environment for
        generating a trajectory for a designated target point.
        """
        self.on_goal = 0
        self.arm_info = [0, 0, 0, -90 * np.pi / 180, 0, 90 * np.pi / 180, 45 * np.pi / 180]

        # Calculate the pose information of TCP by forward kinematics
        T, finger_orient, finger_xyz = self.get_fk_solution(self.arm_info)

        # Calculate normalized x,y,z distances between TCP and goal
        dist1 = [(self.goal_pose['x'] - finger_xyz[0]) / self.dist_norm,
                 (self.goal_pose['y'] - finger_xyz[1]) / self.dist_norm,
                 (self.goal_pose['z'] - finger_xyz[2]) / self.dist_norm]

        # Orientation (alpha,beta,gamma) differences between TCP and goal, normalized
        dist2 = [np.abs(self.goal_pose['alpha'] - finger_orient[0]),
                 np.abs(self.goal_pose['beta'] - finger_orient[1]),
                 np.abs(self.goal_pose['gamma'] - finger_orient[2])]

        for m in range(3):
            if dist2[m] >= 180:
                dist2[m] = np.abs(dist2[m]-360)

        self.distance_old = np.sqrt(dist1[0] ** 2 + dist1[1] ** 2 + dist1[2] ** 2)
        self.orient_old = dist2[0] + dist2[1] + dist2[2]

