+        bounds=(Q_MIN, Q_MAX),
+        ftol=1e-10,
+        xtol=1e-10,
+        gtol=1e-10,
+        max_nfev=500,
+    )
+    residual = float(np.linalg.norm(env.kin.flange(result.x) - env.goal))
+    return result.x, residual
+
