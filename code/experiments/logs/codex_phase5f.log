+        },
+        "sample_episode_velocity_snapshots": [
+            {
+                "episode": ep["episode"],
+                "termination": ep["termination"],
+                "steps": ep["steps"],
+                "norm_rad_s_by_step": ep["snapshots"],
+            }
+            for ep in episodes[:5]
