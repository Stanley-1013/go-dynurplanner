+        print(json.dumps(result, sort_keys=True), flush=True)
+
+    print()
+    _print_table(results)
+    if any(
+        result["counts"][key] > 0
+        for result in results
+        for key in ("endpoint_violation", "inter_sample_violation")
+    ):
