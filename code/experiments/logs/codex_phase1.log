+from godynur.kinodynamics import (
+    acceleration,
+    braking_feasible,
+    continuous_state,
+    discrete_update,
+    interval_extrema,
+    interval_within_limits,
+    position,
+    velocity,
+)
+
+
+@pytest.mark.parametrize(
+    "state,j,h,expected",
+    [
+        (
+            np.array([1.0, 2.0, 3.0]),
+            4.0,
+            0.5,
