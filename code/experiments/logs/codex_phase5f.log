from scipy.optimize import least_squares
from godynur.env import DynArmEnv
from godynur.panda import Q_MIN,Q_MAX

def ik(env,rng):
 q0=env.q.copy();p=env.goal; sols=[]
 for s in [q0]+[Q_MIN+rng.random(7)*(Q_MAX-Q_MIN) for _ in range(5)]:
  z=least_squares(lambda q:env.kin.flange(q)-p,s,bounds=(Q_MIN,Q_MAX),max_nfev=500,ftol=1e-10,xtol=1e-10,gtol=1e-10)
  er=np.linalg.norm(env.kin.flange(z.x)-p); dist=np.max(np.abs(z.x-q0)) # favor minimal max travel
  if er<1e-4: sols.append((dist,z.x))
 return min(sols,key=lambda x:x[0])[1]
for amp in [.2,.3,.4,.5,.6]:
 env=DynArmEnv(task='tabletop',n_obstacles=3,reward_mode='uoar',seed=2010000,action_mode='velocity');env.set_difficulty(0,0);rng=np.random.default_rng(7);succ=0; mins=[];steps=[];falls=0
