)
old_namespace = {\"__name__\": \"old_kinodynamics\"}
exec(compile(source, \"old_kinodynamics.py\", \"exec\"), old_namespace)
old_braking_feasible = old_namespace[\"braking_feasible\"]

rng = np.random.default_rng(20260717)
for case in range(10000):
    q_limit = rng.uniform(0.1, 3.0)
    v_limit = rng.uniform(0.1, 3.0)
    a_limit = rng.uniform(0.1, 5.0)
    j_limit = rng.uniform(0.1, 30.0)
    args = (
        rng.uniform(-1.2 * q_limit, 1.2 * q_limit),
        rng.uniform(-1.2 * v_limit, 1.2 * v_limit),
        rng.uniform(-1.2 * a_limit, 1.2 * a_limit),
        rng.uniform(0.01, 0.3),
