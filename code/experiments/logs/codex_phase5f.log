import sys,numpy as np
sys.path.insert(0,'code')
from scipy.optimize import least_squares
from godynur.env import DynArmEnv
from godynur.panda import Q_MIN,Q_MAX

def ik(env,rng):
 q0=env.q.copy();p=env.goal; sols=[]
 for s in [q0]+[Q_MIN+rng.random(7)*(Q_MAX-Q_MIN) for _ in range(3)]:
  z=least_squares(lambda q:env.kin.flange(q)-p,s,bounds=(Q_MIN,Q_MAX),max_nfev=300)
  er=np.linalg.norm(env.kin.flange(z.x)-p)
  if er<1e-3: sols.append((np.max(np.abs(z.x-q0)),z.x))
