import sys, numpy as np
sys.path.insert(0,'code')
from scipy.optimize import least_squares
from godynur.env import DynArmEnv
from godynur.panda import DQ_MAX,Q_MIN,Q_MAX

def ik(env):
 p=env.goal; q0=env.q.copy(); rng=np.random.default_rng(99)
 starts=[q0]+[Q_MIN+rng.random(7)*(Q_MAX-Q_MIN) for _ in range(6)]
 sols=[]
 def fun(q): return env.kin.flange(q)-p
 for s in starts:
  z=least_squares(fun,s,bounds=(Q_MIN,Q_MAX),xtol=1e-10,ftol=1e-10,gtol=1e-10,max_nfev=500)
  err=np.linalg.norm(fun(z.x))
  sols.append((err,np.linalg.norm((z.x-q0)/(Q_MAX-Q_MIN)),z.x))
 feasible=[x for x in sols if x[0]<1e-4]
 return min(feasible or sols,key=lambda x:(x[1] if feasible else x[0]))

def act(env,qt):
 # joint target velocity, with max 60% physical velocity
 qd=np.clip(2.5*(qt-env.q),-.6*DQ_MAX,.6*DQ_MAX)
 return np.clip((qd-env.v)/env.dv_scale,-1,1)

env=DynArmEnv(task='tabletop',n_obstacles=3,reward_mode='uoar',seed=2010000,action_mode='velocity');env.set_difficulty(0,0)
for ep in range(20):
 env.reset(); d0=np.linalg.norm(env.kin.flange(env.q)-env.goal);err,dist,qt=ik(env); vs=[];ds=[];done=False
 while not done:
  _,_,done=env.step(act(env,qt));vs.append(np.linalg.norm(env.v));ds.append(np.linalg.norm(env.kin.flange(env.q)-env.goal))
 print(ep,'d0',round(d0,3),'ik',round(err,6),'qdist',round(dist,2),'min/end',round(min(ds),3),round(ds[-1],3),'succ' if env.on_goal else 'timeout','steps',env.t,'vmed/max',round(float(np.median(vs)),3),round(max(vs),3))
