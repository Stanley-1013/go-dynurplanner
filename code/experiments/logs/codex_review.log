   366	    def scene_params(self, pad_to: int | None = None) -> np.ndarray:
   367	        """Obstacle snapshot as (pad_to, 9): [center(3), half(3), vel(3)] per
   368	        slot; absent slots filled with a distant dummy (center=50) that
   369	        rasterizes to nothing. The analytic-space replay trick: storing 9
   370	        floats per obstacle instead of voxel grids makes grid-RL replay
   371	        buffers ~4000x smaller; grids are re-rasterized lazily on sampling."""
   372	        n = pad_to if pad_to is not None else self.n_obstacles_max
   373	        out = np.full((n, 9), 50.0, dtype=np.float32)
   374	        out[:, 3:6] = 0.01
   375	        out[:, 6:9] = 0.0
   376	        for i, ob in enumerate(self.scene.obstacles[:n]):
   377	            out[i, 0:3] = ob.center
   378	            out[i, 3:6] = ob.half
   379	            out[i, 6:9] = ob.vel
   380	        return out

