class ArmEnv(object):
    action_bound = [-1.5, 1.5]    # clip the action value to [-1.5, 1.5]
    state_dim = 20
    action_dim = 7
    distance_old = 0
    distance_new = 0
    orient_old = 0
    orient_new = 0

    def __init__(self):
