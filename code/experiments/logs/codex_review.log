   583	        hi = ob.center + ob.half + margin
   584	        gap = _np.maximum(lo - seg_hi, 0.0) + _np.maximum(seg_lo - hi, 0.0)
   585	        dist_lb = float(_np.linalg.norm(gap))
   586	        v_obs = float(_np.linalg.norm(ob.vel))
   587	        v_seg = 1.2 * 7 * self.action_bound[1] / self.dt  # conservative
   588	        return dist_lb <= (v_obs + v_seg) * self.dt + 1e-9
