    v_max: float,
    a_min: float,
    a_max: float,
    j_min: float,
    j_max: float,
) -> float | None:
    """Return the first jerk of the conservative braking witness, if any."""
    return _braking_witness_first_jerk(
        q0,
        v0,
        a0,
        h,
        n_steps,
        q_min,
        q_max,
        v_min,
        v_max,
        a_min,
        a_max,
        j_min,
        j_max,
    )
