diff --git a/code/godynur/kinodynamics.py b/code/godynur/kinodynamics.py
index c6b46d3f3c1be69207857447f9ed969dbf93e729..c1949edd9268733f2d8617d7b559236231a73504
--- a/code/godynur/kinodynamics.py
+++ b/code/godynur/kinodynamics.py
@@ -445,3 +445,81 @@
         j_min,
         j_max,
     )
+
