+            }
+        )
+    summary = summarize("scripted_ik_path", episodes)
+    summary["scripted_amplitude"] = SCRIPTED_AMPLITUDE
+    summary["ik_residual_m"] = {
+        "median": float(np.median(ik_residuals)),
+        "max": float(np.max(ik_residuals)),
