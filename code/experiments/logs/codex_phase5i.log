+    )
+    away_from_limit = velocity_margin(
+        1.99, 0.0, 0.0, -1.0, 0.1, 20, *limits, upper_bound=2.0
+    )
+
+    assert toward_limit < 0.15
+    assert away_from_limit > 1.9

