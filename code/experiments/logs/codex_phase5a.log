+def _parse_arms(value: str) -> list[str]:
+    arms = [arm.strip() for arm in value.split(",") if arm.strip()]
+    invalid = [arm for arm in arms if arm not in ARMS]
+    if not arms or invalid or len(set(arms)) != len(arms):
+        choices = ",".join(ARMS)
