   272	        # temporarily restore q_t while evaluating the executed transition.
   273	        self.q = q_old
   274	        tau_star = self._first_contact(
   275	            q_trajectory_end - q_old, inflation=eps_cubic
   276	        )
   277	        self.last_tau_star = tau_star
   278	        collided = tau_star is not None
   279	        if collided:
   280	            self.last_discrete_missed = not self._endpoint_overlaps(q_old + dq)
   281	
   282	        r = self._reward(dq)
   283	        r -= self.lambda_intervention * self._last_intervention_norm**2
   284	        if collided:
   285	            r -= 5.0
   286	
   287	        self.q = q_old + dq
   288	        self.scene.step(self.dt)
   289	        self.t += 1
   290	        self._grids = self._grids[1:] + [self._rasterize_now()]
   291	
   292	        err = np.linalg.norm(self.kin.flange(self.q) - self.goal)
   293	        if err < self.goal_tol:
   294	            self.on_goal += 1
   295	        else:
   296	            self.on_goal = 0
   297	        done = collided or self.on_goal >= self.goal_dwell or self.t >= self.max_steps
   298	        return self._state(), float(r), bool(done)
   299	
   300	    def sample_action(self) -> np.ndarray:
   301	        return self.rng.uniform(*self.action_bound, self.action_dim)
   302	
   303	    def scene_params(self, pad_to: int | None = None) -> np.ndarray:
   304	        """Obstacle snapshot as (pad_to, 9): [center(3), half(3), vel(3)] per
   305	        slot; absent slots filled with a distant dummy (center=50) that
   306	        rasterizes to nothing. The analytic-space replay trick: storing 9
   307	        floats per obstacle instead of voxel grids makes grid-RL replay
   308	        buffers ~4000x smaller; grids are re-rasterized lazily on sampling."""
   309	        n = pad_to if pad_to is not None else self.n_obstacles_max
   310	        out = np.full((n, 9), 50.0, dtype=np.float32)
   311	        out[:, 3:6] = 0.01
   312	        out[:, 6:9] = 0.0
   313	        for i, ob in enumerate(self.scene.obstacles[:n]):
   314	            out[i, 0:3] = ob.center
   315	            out[i, 3:6] = ob.half
   316	            out[i, 6:9] = ob.vel
   317	        return out
   318	
   319	    # ---- candidate peeking (no state mutation) ----------------------------
   320	    # The analytic parameterized space makes candidate evaluation free: both
   321	    # the immediate reward and the interval-collision verdict of a candidate
   322	    # action are pure functions of (current state, action). This is what
   323	    # APE2's candidate pool exploits (URPlanner) and what the shield needs.
   324	
   325	    def peek_reward(self, action: np.ndarray) -> float:
   326	        """Immediate reward the candidate would receive (excl. terminal
   327	        collision penalty and goal bonus) — APE2's R_IR, analytically."""
   328	        dq = np.clip(np.asarray(action, float), *self.action_bound)
   329	        dq = np.clip(self.q + dq, Q_MIN, Q_MAX) - self.q
   330	        return float(self._reward(dq))
