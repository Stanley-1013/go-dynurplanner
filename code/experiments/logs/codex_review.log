   139	def shielded_actor_action(env, agent, sel, s):
   140	    """M4's deployment-time certification ladder, unchanged."""
   141	    a = agent.act(s, explore=False)
   142	    if env.peek_tau_star(a, sel._inflation(a)) is None:
   143	        return a
   144	    cands = sel._candidates(s)
   145	    certified = [
   146	        c for c in cands
   147	        if env.peek_tau_star(c, sel._inflation(c)) is None
   148	    ]
   149	    if certified:
   150	        sel.stats["scaled"] += 1
   151	        return max(certified, key=lambda c: env.peek_reward(c))
   152	    for alpha in (0.5, 0.25, 0.125, 0.0):
   153	        if env.peek_tau_star(alpha * a, sel._inflation(alpha * a)) is None:
   154	            return alpha * a
   155	    sel.stats["no_safe"] += 1
   156	    cands = sel._candidates(s)
   157	    taus = [
   158	        (env.peek_tau_star(c, sel._inflation(c)) or np.inf, k)
   159	        for k, c in enumerate(cands)
   160	    ]
   161	    return cands[max(taus)[1]]
