   605	        boxes_next = [
   606	            AABB(
   607	                ob.center + ob.vel * self.dt - ob.half - self.a_r,
   608	                ob.center + ob.vel * self.dt + ob.half + self.a_r,
   609	            )
   610	            for ob in self.scene.obstacles
   611	        ]
   612	        for seg in self.kin.segments(q_new):
   613	            for box in boxes_next:
