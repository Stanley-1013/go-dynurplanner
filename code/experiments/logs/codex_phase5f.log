import sys,numpy as np
sys.path.insert(0,'code')
from scipy.optimize import least_squares
from godynur.env import DynArmEnv
from godynur.panda import Q_MIN,Q_MAX

def ik(env):
 p=env.goal;q0=env.q.copy();rng=np.random.default_rng(99); sols=[]
 for s in [q0]+[Q_MIN+rng.random(7)*(Q_MAX-Q_MIN) for _ in range(8)]:
  z=least_squares(lambda q:env.kin.flange(q)-p,s,bounds=(Q_MIN,Q_MAX),max_nfev=1000,xtol=1e-12,ftol=1e-12,gtol=1e-12)
  er=np.linalg.norm(env.kin.flange(z.x)-p);dist=np.linalg.norm((z.x-q0)/(Q_MAX-Q_MIN));sols.append((er,dist,z.x))
 fs=[x for x in sols if x[0]<1e-5];return min(fs,key=lambda x:x[1])
def resp(dv,H):
 h=.05;lam=1e-3;q=v=a=0.
 for _ in range(H):
  b=.5*h*h;j=b*(dv-a*h)/(b*b+lam);q+=v*h+.5*a*h*h+j*h**3/6;v+=a*h+.5*j*h*h;a+=j*h
 return q

env=DynArmEnv(task='tabletop',n_obstacles=3,reward_mode='uoar',seed=2010000,action_mode='velocity');env.set_difficulty(0,0)
for ep in range(20):
 env.reset();q0=env.q.copy(); d0=np.linalg.norm(env.kin.flange(q0)-env.goal);er,dist,qt=ik(env);delta=qt-q0
 H=next((h for h in range(20,96) if np.max(np.abs(delta)/np.array([resp(x,h) for x in env.dv_scale]))<=.9),95)
 u=delta/np.array([resp(x,H) for x in env.dv_scale]);u=np.clip(u,-1,1);ds=[];vs=[];done=False
 while not done:
  _,_,done=env.step(u);ds.append(np.linalg.norm(env.kin.flange(env.q)-env.goal));vs.append(np.linalg.norm(env.v))
 print(ep,'d0',round(d0,3),'H',H,'umax',round(max(abs(u)),2),'min/end',round(min(ds),3),round(ds[-1],3),'succ' if env.on_goal else 'timeout','step',env.t,'vmed/max',round(float(np.median(vs)),3),round(max(vs),3),'acc',sum(env._last_terminal_membership for _ in [0]))
