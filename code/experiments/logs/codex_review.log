    30	class ReplayBuffer:
    31	    def __init__(self, state_dim, action_dim, capacity=200_000):
    32	        self.s = np.zeros((capacity, state_dim), np.float32)
    33	        self.a = np.zeros((capacity, action_dim), np.float32)
    34	        self.r = np.zeros((capacity, 1), np.float32)
