+        },
+        # RMS fraction across joints: 1.0 means every joint is at its DQ_MAX.
+        "velocity_dqmax_rms_fraction": {
+            "mean": float(np.mean(velocity_fractions)),
+            "median": float(np.median(velocity_fractions)),
