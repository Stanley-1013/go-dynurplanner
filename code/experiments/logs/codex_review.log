    41	        self.s[i], self.a[i], self.r[i], self.s2[i], self.d[i] = s, a, r, s2, d
    42	        self.idx = (i + 1) % self.capacity
    43	        self.full = self.full or self.idx == 0
    44	
    45	    def sample(self, batch):
