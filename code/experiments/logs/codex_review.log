   574	    def _pair_can_contact(self, seg_lo, seg_hi, ob, margin: float) -> bool:
   575	        """Conservative broad-phase: False only if the pair provably cannot
   576	        touch within dt. Segment AABB vs obstacle box gap (L2 lower bound
   577	        via per-axis gaps) compared against max closure = (|v_obs| +
   578	        v_seg_max) * dt, where v_seg_max bounds link-point speed by total
   579	        arm length * max joint speed... we use the action-clip kinematic
   580	        bound: |dq|_1 * R_max / dt with R_max ~ 1.2 m, plus margin slack."""
