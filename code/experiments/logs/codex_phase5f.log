+        "shield_intervention_rate": (
+            sum(ep["interventions"] for ep in episodes)
+            / sum(ep["steps"] for ep in episodes)
+        ),
+    }
+    return result
+
+
+def rollout_scripted(n_episodes: int) -> tuple[dict, list[dict]]:
+    env = make_stage0_env()
+    episodes = []
+    ik_residuals = []
