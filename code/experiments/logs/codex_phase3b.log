+    assert env.stats.get("shield_fallback", 0) == 0
+    assert np.all(env.q >= Q_MIN)
+    assert np.all(env.q <= Q_MAX)
+    assert np.all(env.v >= -DQ_MAX)
+    assert np.all(env.v <= DQ_MAX)
+
+
+def test_velocity_reward_subtracts_intervention_penalty_only():
