from time import perf_counter
import numpy as np
from godynur.env import DynArmEnv
from godynur.panda import Q_MIN, Q_MAX

N = 100
q = (Q_MIN + Q_MAX) / 2.0

env = DynArmEnv(action_mode='velocity', n_obstacles=0, obstacles_in_state=False, seed=123)
env.reset()
env.q = q.copy()
t0 = perf_counter()
for _ in range(N):
    env._velocity_margins(env.q, env.v, env.a)
helper_ms = (perf_counter() - t0) * 1000.0 / N

def prepared(seed):
    e = DynArmEnv(action_mode='velocity', n_obstacles=0, obstacles_in_state=False, seed=seed)
    e.reset()
    e.q = q.copy()
    e._first_contact = lambda dq, inflation=0.0: None
    return e

action = np.zeros(7)
full = prepared(124)
t0 = perf_counter()
for _ in range(N):
    full._step_velocity(action)
full_ms = (perf_counter() - t0) * 1000.0 / N

without = prepared(125)
without._velocity_margins = lambda q, v, a: (np.zeros(7), np.zeros(7))
t0 = perf_counter()
for _ in range(N):
    without._step_velocity(action)
without_ms = (perf_counter() - t0) * 1000.0 / N

print(f'helper_ms_per_call={helper_ms:.6f}')
print(f'step_with_margin_ms={full_ms:.6f}')
print(f'step_without_margin_ms={without_ms:.6f}')
print(f'paired_added_ms={full_ms-without_ms:.6f}')
