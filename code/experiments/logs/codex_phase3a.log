        -q_limit,
        q_limit,
        -v_limit,
        v_limit,
        -a_limit,
        a_limit,
        -j_limit,
        j_limit,
    )
    old_result = old_braking_feasible(*args)
    new_result = new_braking_feasible(*args)
    if old_result "'!= new_result:
        raise AssertionError((case, args, old_result, new_result))
print("10000 randomized braking_feasible cases matched the pre-refactor implementation")
