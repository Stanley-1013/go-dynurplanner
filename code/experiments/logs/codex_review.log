   212	        counts_after = _kinodynamic_counts(env)
   213	        eval_stats = {
   214	            key: counts_after[key] - counts_before[key]
   215	            for key in counts_after
   216	        }
   217	
   218	    return {
   219	        "success": succ / EVAL_EPISODES,
   220	        "collision": coll / EVAL_EPISODES,
   221	        "mean_steps": steps / EVAL_EPISODES,
   222	        "mean_steps_to_success": (
   223	            float(np.mean(success_steps)) if success_steps else None
   224	        ),
   225	        "eval_shield_stats": eval_stats,
   226	        "eval_intervention_rate": (
   227	            intervention_steps / steps if arm == "kinodynamic_shield" else None
   228	        ),
   229	        "eval_mean_intervention_norm": (
   230	            intervention_norm_sum / steps
   231	            if arm == "kinodynamic_shield"
   232	            else None
   233	        ),
   234	        "eval_episode_wall_s": [round(value, 6) for value in episode_wall_s],
   235	        "eval_mean_episode_wall_s": float(np.mean(episode_wall_s)),
   236	    }
   237	
   238	
   239	def run_one(
   240	    arm: str,
   241	    reward_mode: str,
   242	    episodes: int,
   243	    seed: int,
   244	    out_dir: Path,
   245	    dv_scale_mult: float = 1.0,
   246	    expl_noise: float = 0.25,
   247	    gamma: float = 0.98,
   248	):
   249	    action_mode = "velocity" if arm == "kinodynamic_shield" else "delta_q"
   250	    env_kwargs = dict(
   251	        task="tabletop",
   252	        n_obstacles=3,
   253	        reward_mode=reward_mode,
   254	        action_mode=action_mode,
   255	    )
   256	    if action_mode == "velocity" and dv_scale_mult != 1.0:
   257	        env_kwargs["dv_scale"] = DQ_MAX * DynArmEnv.dt * dv_scale_mult
   258	    env = DynArmEnv(seed=seed, **env_kwargs)
   259	    eval_env = DynArmEnv(seed=10_000 + seed, **env_kwargs)
   260	    differentiable_projection = (
   261	        build_diffqp_projection(env) if arm == "kinodynamic_shield" else None
   262	    )
   263	    agent = TD3(
   264	        env.state_dim,
   265	        env.action_dim,
   266	        action_scale=env.action_bound[1],
   267	        expl_noise=expl_noise,
   268	        gamma=gamma,
   269	        seed=seed,
   270	        differentiable_projection=differentiable_projection,
   271	    )
   272	    sel = make_selector(env, agent, seed) if arm == "ape2_shield" else None
   273	    stage_idx = 0
   274	    env.set_difficulty(*STAGES[stage_idx])
   275	    rolling = deque(maxlen=ADVANCE_WINDOW)
   276	    history = []
   277	    total_steps = 0
   278	    t0 = time.perf_counter()
   279	
   280	    block_steps = 0
   281	    block_interventions = 0
   282	    block_intervention_norm = 0.0
   283	    block_episode_wall_s: list[float] = []
   284	
   285	    for ep in range(1, episodes + 1):
   286	        episode_t0 = time.perf_counter()
   287	        s = env.reset()
   288	        done = False
   289	        while not done:
   290	            if total_steps < WARMUP_STEPS:
   291	                a = env.sample_action()
   292	                if arm == "ape2_shield":
   293	                    cand = a
   294	                    a = None
   295	                    for alpha in (1.0, 0.5, 0.25, 0.0):
   296	                        if (
   297	                            env.peek_tau_star(
   298	                                alpha * cand, sel._inflation(alpha * cand)
   299	                            )
   300	                            is None
   301	                        ):
   302	                            a = alpha * cand
   303	                            break
   304	                    if a is None:
   305	                        a = cand
   306	            elif arm == "ape2_shield":
   307	                a = sel.act(s, step=total_steps)
   308	            else:
   309	                a = agent.act(s, explore=True)
   310	
   311	            s2, r, done = env.step(a)
   312	            buffer_action = (
   313	                env._last_executed_action
   314	                if arm == "kinodynamic_shield"
   315	                else a
   316	            )
   317	            agent.buffer.add(s, buffer_action, r, s2, float(done))
   318	            agent.learn()
   319	            s = s2
   320	            total_steps += 1
   321	            block_steps += 1
   322	            if arm == "kinodynamic_shield":
   323	                block_interventions += int(not env._last_terminal_membership)
   324	                block_intervention_norm += env._last_intervention_norm
   325	
   326	        block_episode_wall_s.append(time.perf_counter() - episode_t0)
   327	        rolling.append(1 if env.on_goal >= env.goal_dwell else 0)
   328	
   329	        if (
   330	            stage_idx < len(STAGES) - 1
   331	            and len(rolling) == ADVANCE_WINDOW
   332	            and np.mean(rolling) >= ADVANCE_THRESHOLD
   333	        ):
   334	            stage_idx += 1
   335	            env.set_difficulty(*STAGES[stage_idx])
   336	            rolling.clear()
   337	            print(
   338	                f"[{arm} seed{seed}] ep {ep}: ADVANCE to stage "
   339	                f"{stage_idx} {STAGES[stage_idx]}",
   340	                flush=True,
   341	            )
   342	
   343	        if ep % EVAL_EVERY == 0 or ep == episodes:
   344	            ev = evaluate(eval_env, agent, arm, seed)
   345	            ev.update(
   346	                {
   347	                    "episode": ep,
   348	                    "stage": stage_idx,
   349	                    "actual_seed": seed,
   350	                    "train_rolling_succ": (
   351	                        float(np.mean(rolling)) if rolling else 0.0
   352	                    ),
   353	                    "wall_s": round(time.perf_counter() - t0, 1),
   354	                    "train_shield_stats": dict(sel.stats) if sel else {},
   355	                    "train_env_stats": (
   356	                        _kinodynamic_counts(env)
   357	                        if arm == "kinodynamic_shield"
   358	                        else {}
   359	                    ),
   360	                    # Block-local values make intervention-over-training trends
   361	                    # directly comparable at every EVAL_EVERY checkpoint.
   362	                    "train_intervention_rate": (
   363	                        block_interventions / block_steps
   364	                        if arm == "kinodynamic_shield"
   365	                        else None
   366	                    ),
   367	                    "train_mean_intervention_norm": (
   368	                        block_intervention_norm / block_steps
   369	                        if arm == "kinodynamic_shield"
   370	                        else None
   371	                    ),
   372	                    "train_episode_wall_s": [
   373	                        round(value, 6) for value in block_episode_wall_s
   374	                    ],
   375	                    "train_mean_episode_wall_s": float(
   376	                        np.mean(block_episode_wall_s)
   377	                    ),
   378	                }
   379	            )
   380	            history.append(ev)
   381	            no_safe = sel.stats["no_safe"] if sel else 0
   382	            intervention = ev["train_intervention_rate"]
   383	            intervention_text = (
   384	                f" | intervene {intervention:.3f}"
   385	                if intervention is not None
   386	                else ""
   387	            )
   388	            print(
   389	                f"[{arm} seed{seed}] ep {ep:>4} | stage {stage_idx} | "
   390	                f"succ {ev['success']:.2f} | true-coll {ev['collision']:.2f} "
   391	                f"| no_safe {no_safe}{intervention_text} | {ev['wall_s']}s",
   392	                flush=True,
   393	            )
   394	            block_steps = 0
   395	            block_interventions = 0
   396	            block_intervention_norm = 0.0
   397	            block_episode_wall_s = []
   398	
   399	    torch.save(
   400	        {
   401	            "actor": agent.actor.state_dict(),
   402	            "q1": agent.q1.state_dict(),
   403	            "q2": agent.q2.state_dict(),
   404	        },
   405	        out_dir / f"td3_{arm}_seed{seed}.pt",
   406	    )
   407	    return history
   408	
   409	
   410	def _parse_arms(value: str) -> list[str]:
   411	    arms = [arm.strip() for arm in value.split(",") if arm.strip()]
   412	    invalid = [arm for arm in arms if arm not in ARMS]
   413	    if not arms or invalid or len(set(arms)) != len(arms):
   414	        choices = ",".join(ARMS)
   415	        raise argparse.ArgumentTypeError(
   416	            f"choose a unique comma-separated subset of {choices}"
   417	        )
   418	    return arms
   419	
   420	
   421	def main():
   422	    ap = argparse.ArgumentParser()
   423	    ap.add_argument("--episodes", type=int, default=300)
   424	    ap.add_argument("--seeds", type=int, default=2)
   425	    ap.add_argument(
   426	        "--seed-salt",
   427	        type=int,
   428	        default=0,
   429	        help="added to disjoint per-arm seed ranges (M5 seed-confound fix)",
   430	    )
   431	    ap.add_argument(
   432	        "--arms",
   433	        type=_parse_arms,
   434	        default=list(ARMS),
   435	        help="comma-separated subset of no_shield,ape2_shield,kinodynamic_shield",
   436	    )
   437	    ap.add_argument("--reward-mode", type=str, default="uoar")
   438	    ap.add_argument(
   439	        "--out", type=str, default="experiments/results/m6_kinodynamic"
   440	    )
   441	    ap.add_argument(
   442	        "--dv-scale-mult",
   443	        type=float,
   444	        default=1.0,
   445	        help="multiplier on kinodynamic_shield's default dv_scale "
   446	        "(DQ_MAX*dt); Phase 5-track RL-convergence sweep knob",
   447	    )
   448	    ap.add_argument(
   449	        "--expl-noise",
   450	        type=float,
   451	        default=0.25,
   452	        help="TD3 Gaussian exploration noise stddev",
   453	    )
   454	    ap.add_argument(
   455	        "--gamma",
   456	        type=float,
   457	        default=0.98,
   458	        help="TD3 discount factor",
   459	    )
   460	    args = ap.parse_args()
   461	    if args.episodes < 1 or args.seeds < 1:
   462	        ap.error("--episodes and --seeds must be positive")
   463	    if args.seeds >= ARM_SEED_STRIDE:
   464	        ap.error(f"--seeds must be less than {ARM_SEED_STRIDE}")
   465	
   466	    out_dir = Path(args.out)
   467	    out_dir.mkdir(parents=True, exist_ok=True)
   468	    results = {}
   469	    for arm in args.arms:
   470	        results[arm] = {}
   471	        arm_offset = ARMS.index(arm) * ARM_SEED_STRIDE
   472	        for seed_index in range(args.seeds):
   473	            actual_seed = args.seed_salt + arm_offset + seed_index
   474	            results[arm][seed_index] = run_one(
   475	                arm,
   476	                args.reward_mode,
   477	                args.episodes,
   478	                actual_seed,
   479	                out_dir,
   480	                dv_scale_mult=args.dv_scale_mult,
   481	                expl_noise=args.expl_noise,
   482	                gamma=args.gamma,
   483	            )
   484	
   485	    arm_tag = "-".join(args.arms)
   486	    json_path = out_dir / f"m6_{args.reward_mode}_{arm_tag}_salt{args.seed_salt}.json"
   487	    config = vars(args).copy()
   488	    config["arms"] = args.arms
   489	    with open(json_path, "w") as f:
   490	        json.dump(
   491	            {"config": config, "stages": STAGES, "results": results},
   492	            f,
   493	            indent=2,
   494	        )
   495	
   496	    for arm in results:
   497	        fin = [results[arm][seed][-1] for seed in results[arm]]
   498	        print(
   499	            f"{arm:>19} final: succ "
   500	            f"{np.mean([record['success'] for record in fin]):.2f} "
   501	            f"| true-coll "
   502	            f"{np.mean([record['collision'] for record in fin]):.2f}"
   503	        )
   504	    print(f"results: {json_path}")
   505	
   506	
   507	if __name__ == "__main__":
   508	    main()

