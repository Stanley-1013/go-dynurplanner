    63	def build_diffqp_projection(env: DynArmEnv):
    64	    """Build the velocity arm's observation-aware differentiable shield."""
    65	    if env.action_mode != "velocity":
    66	        raise ValueError("differentiable QP projection requires velocity mode")
    67	
    68	    # Keep this in lockstep with DynArmEnv._state(): the fixed 17-value base
    69	    # is followed by padded obstacle slots and then the optional closest-point
    70	    # block before the velocity-mode fields begin.
    71	    velocity_offset = 17
    72	    if env.obstacles_in_state:
    73	        velocity_offset += 6 * env.n_obstacles_max
    74	    if env.closest_point_in_state:
    75	        velocity_offset += 7
    76	    velocity_slice = slice(velocity_offset, velocity_offset + env.action_dim)
    77	    acceleration_slice = slice(
    78	        velocity_offset + env.action_dim,
    79	        velocity_offset + 2 * env.action_dim,
    80	    )
    81	
    82	    dv_scale_numpy = env.dv_scale.copy()
    83	    safety_n_steps = env.safety_n_steps
    84	
    85	    def differentiable_projection(raw_action_batch, state_batch):
    86	        tensor_options = {
    87	            "dtype": state_batch.dtype,
    88	            "device": state_batch.device,
    89	        }
    90	        q_min = torch.as_tensor(Q_MIN, **tensor_options)
    91	        q_max = torch.as_tensor(Q_MAX, **tensor_options)
    92	        dq_max = torch.as_tensor(DQ_MAX, **tensor_options)
    93	        ddq_max = torch.as_tensor(DDQ_MAX, **tensor_options)
    94	        dv_scale = torch.as_tensor(dv_scale_numpy, **tensor_options)
    95	
    96	        q_norm = state_batch[:, : env.action_dim]
    97	        q_batch = (q_norm + 1.0) * 0.5 * (q_max - q_min) + q_min
    98	        v_batch = state_batch[:, velocity_slice] * dq_max
    99	        a_batch = state_batch[:, acceleration_slice] * ddq_max
   100	        v_nom_batch = v_batch + dv_scale * raw_action_batch
   101	
   102	        v_exec = differentiable_v_exec(
   103	            q_batch.detach().cpu().numpy(),
   104	            v_batch.detach().cpu().numpy(),
   105	            a_batch.detach().cpu().numpy(),
   106	            v_nom_batch,
   107	            h=env.dt,
   108	            n_steps=safety_n_steps,
   109	            q_min=Q_MIN,
   110	            q_max=Q_MAX,
   111	            v_min=-DQ_MAX,
   112	            v_max=DQ_MAX,
   113	            a_min=-DDQ_MAX,
   114	            a_max=DDQ_MAX,
   115	            j_min=-DDDQ_MAX,
   116	            j_max=DDDQ_MAX,
   117	        )
   118	        return ((v_exec - v_batch) / dv_scale).clamp(-1.0, 1.0)
   119	
   120	    return differentiable_projection
